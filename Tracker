</div>

<script>
  const wdInput       = document.getElementById('wdInput');
  const muList        = document.getElementById('muList');
  const emptyState    = document.getElementById('emptyState');
  const clearBtn      = document.getElementById('clearBtn');
  const goalInput     = document.getElementById('goalInput');
  const operatorInput = document.getElementById('operatorInput');
  const bigNum        = document.getElementById('bigNum');
  const ringPct       = document.getElementById('ringPct');
  const ringFill      = document.getElementById('ringFill');
  const progFill      = document.getElementById('progressFill');
  const progPct       = document.getElementById('progPct');
  const statTotal     = document.getElementById('statTotal');
  const statLines     = document.getElementById('statLines');
  const statRemain    = document.getElementById('statRemain');
  const doneBanner    = document.getElementById('doneBanner');
  const doneCount     = document.getElementById('doneCount');
  const bannerUser    = document.getElementById('bannerUser');

  let entries = [];
  const CIRCUMFERENCE = 2 * Math.PI * 100; // ~628.3

  function getGoal() {
    return Math.max(1, parseInt(goalInput.value) || 1000);
  }

  function getOperatorName() {
    return operatorInput.value.trim() || "Operator";
  }

  function parseWD(text) {
    const regex = /([^\n\r]+?)\s*\((\d+)\s+packages?\)/gi;
    const found = [];
    let match;
    while ((match = regex.exec(text)) !== null) {
      found.push({ name: match[1].trim(), count: parseInt(match[2]) });
    }
    return found;
  }

  function animateNumber(el, to) {
    const from = parseInt(el.textContent.replace(/,/g,'')) || 0;
    const dur = 600;
    const start = performance.now();
    function step(now) {
      const p = Math.min((now - start) / dur, 1);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(from + (to - from) * ease).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function updateUI() {
    const goal = getGoal();
    const total = entries.reduce((s, e) => s + e.count, 0);
    const pct = Math.min(total / goal, 1);
    const remaining = Math.max(goal - total, 0);
    const currentOperator = getOperatorName();

    // Animate numbers
    animateNumber(bigNum, total);
    animateNumber(statTotal, total);
    animateNumber(statLines, entries.length);
    animateNumber(statRemain, remaining);

    // Ring
    const offset = CIRCUMFERENCE - pct * CIRCUMFERENCE;
    ringFill.style.strokeDashoffset = offset;
    ringFill.style.strokeDasharray = CIRCUMFERENCE;
    ringPct.textContent = Math.round(pct * 100) + '%';
    if (pct >= 1) ringFill.classList.add('done');
    else ringFill.classList.remove('done');

    // Progress bar
    progFill.style.width = (pct * 100) + '%';
    progPct.textContent = total.toLocaleString() + ' / ' + goal.toLocaleString();

    // Milestones
    const milestones = [
      { id: 'm250', val: goal * 0.25 },
      { id: 'm500', val: goal * 0.50 },
      { id: 'm750', val: goal * 0.75 },
      { id: 'm1000', val: goal },
    ];
    const pctLabels = ['25%','50%','75%','100%'];
    milestones.forEach((m, i) => {
      const el = document.getElementById(m.id);
      el.querySelector('.m-val').textContent = Math.round(m.val).toLocaleString();
      el.querySelector('.m-label').textContent = pctLabels[i];
      if (total >= m.val) el.classList.add('reached');
      else el.classList.remove('reached');
    });

    // Done banner personalization
    if (total >= goal) {
      doneBanner.classList.add('show');
      doneCount.textContent = total.toLocaleString();
      bannerUser.textContent = currentOperator;
    } else {
      doneBanner.classList.remove('show');
    }

    // Render list
    renderList();
  }

  function renderList() {
    muList.innerHTML = '';
    if (entries.length === 0) {
      muList.appendChild(emptyState);
      return;
    }
    entries.forEach((e, i) => {
      const item = document.createElement('div');
      item.className = 'mu-item';
      item.style.animationDelay = (i * 0.03) + 's';
      item.innerHTML = `
        <div class="mu-index">#${i + 1}</div>
        <div class="mu-name">
          <strong>${escapeHTML(e.name)}</strong>
          packages
        </div>
        <div class="mu-pkg">+${e.count}</div>
      `;
      muList.appendChild(item);
    });
  }

  function escapeHTML(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Live parse on paste/type
  wdInput.addEventListener('input', () => {
    const parsed = parseWD(wdInput.value);
    entries = parsed;
    updateUI();
  });

  // Handle paste event
  wdInput.addEventListener('paste', () => {
    setTimeout(() => {
      const parsed = parseWD(wdInput.value);
      entries = parsed;
      updateUI();
    }, 10);
  });

  goalInput.addEventListener('input', updateUI);
  operatorInput.addEventListener('input', updateUI);

  clearBtn.addEventListener('click', () => {
    wdInput.value = '';
    entries = [];
    updateUI();
  });

  // Init
  updateUI();
</script>
</body>
</html>

