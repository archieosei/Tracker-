      <div class="stat-sub">accumulated</div>
    </div>
    <div class="stat-card highlight2">
      <div class="stat-label">MU Lines</div>
      <div class="stat-value" id="statLines">0</div>
      <div class="stat-sub">parsed</div>
    </div>
    <div class="stat-card highlight3">
      <div class="stat-label">Remaining</div>
      <div class="stat-value" id="statRemain">1000</div>
      <div class="stat-sub">to goal</div>
    </div>
  </div>

  <div class="progress-section">
    <div class="progress-header">
      <span>PROGRESS TO GOAL</span>
      <span class="progress-pct" id="progPct">0 / 1000</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progressFill"></div>
    </div>
    <div class="milestones">
      <div class="milestone" id="m250">
        <div class="m-val">250</div>
        <div class="m-label">25%</div>
        <div class="m-check">REACHED</div>
      </div>
      <div class="milestone" id="m500">
        <div class="m-val">500</div>
        <div class="m-label">50%</div>
        <div class="m-check">REACHED</div>
      </div>
      <div class="milestone" id="m750">
        <div class="m-val">750</div>
        <div class="m-label">75%</div>
        <div class="m-check">REACHED</div>
      </div>
      <div class="milestone" id="m1000">
